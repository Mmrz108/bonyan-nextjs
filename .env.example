# Local SQLite (used by Prisma CLI + Next.js)
BONYAN_DATABASE_URL="file:./dev.db"

# JWT signing secret — change in production
AUTH_SECRET="bonyan-dev-secret-change-me-in-production-32chars"

# Demo admin seeded on first API request
DEMO_ADMIN_EMAIL="admin@bonyan.local"
DEMO_ADMIN_PASSWORD="Admin123!@#"

# Legacy Django URL (optional; web app no longer requires it)
# API_URL=http://localhost:8000
